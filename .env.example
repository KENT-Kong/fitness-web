# 健身网站 - Google Sheets + AI助手集成
# 将此文件复制为 .env 并填入相应的值

# ==================== Google Sheets 配置 ====================
# 获取方式：https://console.cloud.google.com/apis/credentials
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# Google Sheets ID（从URL中获取：https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit）
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ==================== DeepSeek AI 配置 ====================
# 获取方式：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==================== 服务器配置 ====================
PORT=8080
HOST=0.0.0.0
CACHE_DURATION=300000  # 5分钟（毫秒）

# ==================== 安全配置 ====================
# 允许的跨域来源，用逗号分隔
ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com

# ==================== 健身数据配置 ====================
# 用户的健身目标（会从Google Sheets中读取，这里作为备用）
USER_TARGET_WEIGHT=80
USER_START_WEIGHT=100.6
USER_CURRENT_WEIGHT=94.8
USER_BODY_FAT=28.1
DEADLINE_DATE=2026-06-30

# ==================== 部署配置 ====================
# Cloudflare Pages 或类似部署平台
NODE_ENV=production